---
/**
 * Radar mark: lime rings + red contact blips.
 * Pass `seedDate` (usually article pubDate) to place blips from time;
 * omit for the stable brand mark (header).
 */
import {
  BRAND_RADAR_BLIPS,
  radarBlipsFromDate,
  type RadarBlip,
} from '../utils/radarBlips';

interface Props {
  class?: string;
  size?: number;
  seedDate?: Date;
}

const { class: className = '', size = 28, seedDate } = Astro.props;

const blips: RadarBlip[] = seedDate
  ? radarBlipsFromDate(seedDate)
  : BRAND_RADAR_BLIPS;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <circle cx="16" cy="16" r="15" fill="var(--color-ink)"></circle>
  <circle
    cx="16"
    cy="16"
    r="11"
    stroke="var(--color-radar)"
    stroke-width="1.75"
    opacity="0.35"></circle>
  <circle
    cx="16"
    cy="16"
    r="7.5"
    stroke="var(--color-radar)"
    stroke-width="1.75"></circle>
  <circle
    cx="16"
    cy="16"
    r="3.75"
    stroke="var(--color-radar)"
    stroke-width="1.75"></circle>
  {
    blips.map((b) => (
      <circle
        cx={b.cx}
        cy={b.cy}
        r={b.r}
        fill="var(--color-breaking)"
        opacity={b.opacity ?? 1}
      />
    ))
  }
</svg>
