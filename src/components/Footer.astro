---
import { SITE_NAME, SOCIAL_LINKS } from '../consts';
import SocialIcon from './SocialIcon.astro';
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="footer-signup">
        <p class="footer-signup__label">Get breaking travel news</p>
        <div class="footer-signup__beehiiv">
          <script
            async
            src="https://subscribe-forms.beehiiv.com/v3/loader.js"
            data-beehiiv-form="afa8077b-0891-4511-a3f9-527e5748637d"
            is:inline
          ></script>
        </div>
      </div>

      <div class="site-footer__social">
        <p class="site-footer__social-label">Follow</p>
        <ul class="social-list">
          {
            SOCIAL_LINKS.map((item) => (
              <li>
                <a
                  class="social-link"
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer me"
                  aria-label={item.label}
                  title={item.label}
                >
                  <SocialIcon network={item.id} />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="site-footer__bottom">
      <nav class="site-footer__nav" aria-label="Footer">
        <a href="/about/">About</a>
        <span class="site-footer__sep" aria-hidden="true">·</span>
        <a href="/contact/">Contact</a>
        <span class="site-footer__sep" aria-hidden="true">·</span>
        <a href="/privacy/">Privacy</a>
        <span class="site-footer__sep" aria-hidden="true">·</span>
        <a href="/terms/">Terms</a>
      </nav>
      <p class="site-footer__copy">
        {`© ${new Date().getFullYear()} ${SITE_NAME}`}
      </p>
    </div>
  </div>
</footer>
