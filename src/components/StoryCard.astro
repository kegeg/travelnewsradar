---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  lead?: boolean;
}

const { article, lead = false } = Astro.props;
const href = `/news/${article.id}/`;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'America/New_York',
  });
}
---

<li>
  <a class:list={['story', lead && 'story--lead']} href={href}>
    <div class="story__meta">
      {
        article.data.breaking && (
          <span class="badge-breaking">Breaking</span>
        )
      }
      <time datetime={article.data.pubDate.toISOString()}>
        {formatDate(article.data.pubDate)}
      </time>
    </div>
    <h2 class="story__title">{article.data.title}</h2>
    <p class="story__dek">{article.data.description}</p>
  </a>
</li>
