---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  variant?: 'lead' | 'card';
}

const { article, variant = 'card' } = Astro.props;
const href = `/news/${article.id}/`;
const image = article.data.image;
const imageAlt = article.data.imageAlt ?? '';

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'America/New_York',
  });
}
---

<li class:list={['story-item', `story-item--${variant}`]}>
  <a class:list={['story', `story--${variant}`]} href={href}>
    {
      image && (
        <div class="story__media">
          <img
            src={image}
            alt={imageAlt}
            width={1200}
            height={480}
            loading={variant === 'lead' ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      )
    }
    <div class="story__body">
      <div class="story__meta">
        {
          article.data.breaking && (
            <span class="badge-breaking">Breaking</span>
          )
        }
        <time datetime={article.data.pubDate.toISOString()}>
          {formatDate(article.data.pubDate)}
        </time>
      </div>
      <h2 class="story__title">{article.data.title}</h2>
      <p class="story__dek">{article.data.description}</p>
    </div>
  </a>
</li>
