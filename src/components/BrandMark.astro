---
/**
 * TNR mark: navy TN + red R + light-blue signal arcs above the R (v1 brand).
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['tnr-mark', className]} aria-hidden="true">
  <span class="tnr-mark__letters"
    >TN<span class="tnr-mark__r">R</span></span
  >
  <svg
    class="tnr-mark__arcs"
    viewBox="0 0 24 20"
    width="22"
    height="18"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Arcs radiate up/right from above the R (wifi-style), not through the letter -->
    <path
      d="M4 16c3.2-3.8 7.8-6 12.5-6"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"></path>
    <path
      d="M4 16c4.6-5.6 10.8-8.8 17-8.8"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      opacity="0.9"></path>
    <path
      d="M4 16c5.8-7.2 13.5-11 20.5-11"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      opacity="0.75"></path>
    <circle cx="4" cy="16" r="1.7" fill="currentColor"></circle>
  </svg>
</span>

<style>
  .tnr-mark {
    position: relative;
    display: inline-flex;
    align-items: flex-end;
    padding-right: 0.85rem;
    padding-top: 0.45rem;
    line-height: 1;
    color: var(--color-radar);
  }

  .tnr-mark__letters {
    font-size: 1.65rem;
    font-weight: 800;
    letter-spacing: -0.06em;
    color: var(--color-ink);
  }

  .tnr-mark__r {
    position: relative;
    color: var(--color-breaking);
  }

  .tnr-mark__arcs {
    position: absolute;
    top: 0;
    right: 0;
    pointer-events: none;
  }
</style>
