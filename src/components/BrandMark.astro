---
/**
 * TNR mark: navy TN + red R + light-blue signal arcs (v1 brand).
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['tnr-mark', className]} aria-hidden="true">
  <span class="tnr-mark__letters"
    >TN<span class="tnr-mark__r">R</span></span
  >
  <svg
    class="tnr-mark__arcs"
    viewBox="0 0 28 28"
    width="18"
    height="18"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M6 16c5 2.6 8.5 7.2 8.5 12.5"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"></path>
    <path
      d="M2 12c8 3.8 13.5 10.5 13.5 18"
      stroke="currentColor"
      stroke-width="2.4"
      stroke-linecap="round"
      opacity="0.85"></path>
    <circle cx="6" cy="16" r="1.8" fill="currentColor"></circle>
    <circle cx="2" cy="12" r="1.8" fill="currentColor"></circle>
  </svg>
</span>

<style>
  .tnr-mark {
    position: relative;
    display: inline-flex;
    align-items: flex-start;
    line-height: 1;
    color: var(--color-radar);
  }

  .tnr-mark__letters {
    font-size: 1.65rem;
    font-weight: 800;
    letter-spacing: -0.06em;
    color: var(--color-ink);
  }

  .tnr-mark__r {
    color: var(--color-breaking);
  }

  .tnr-mark__arcs {
    position: absolute;
    top: -0.15rem;
    right: -0.85rem;
    pointer-events: none;
  }
</style>
