---
/**
 * Exact v1 TNR mark (navy TN, red R, blue arcs) from brand exploration asset.
 */
interface Props {
  class?: string;
  /** Display height in CSS pixels */
  height?: number;
}

const { class: className = '', height = 36 } = Astro.props;
---

<img
  class:list={['tnr-mark', className]}
  src="/brand/tnr-mark.png"
  alt=""
  width={Math.round((height * 920) / 415)}
  height={height}
  decoding="async"
/>
