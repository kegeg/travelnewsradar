---
import { CATEGORIES, categorySlug } from '../consts';
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="TravelNewsRadar home">
      <img
        class="brand__logo"
        src="/brand/tnr-lockup.png"
        alt="Travel News Radar"
        width="200"
        height="111"
        decoding="async"
      />
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/">Latest</a>
      {
        CATEGORIES.map((category) => (
          <a href={`/category/${categorySlug(category)}/`}>{category}</a>
        ))
      }
    </nav>
  </div>
</header>
