---
import '../styles/global.css';
import {
  DEFAULT_OG_IMAGE,
  ORGANIZATION_SAME_AS,
  PUBLISHER_LOGO,
  SITE_DESCRIPTION,
  SITE_NAME,
  SITE_TAGLINE,
  SITE_URL,
} from '../consts';
import { absUrl } from '../utils/images';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: URL | string;
  ogType?: 'website' | 'article';
  /** Absolute or site-relative image for og:image / twitter:image */
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  canonicalURL = Astro.site
    ? new URL(Astro.url.pathname, Astro.site)
    : Astro.url,
  ogType = 'website',
  ogImage = DEFAULT_OG_IMAGE,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  jsonLd,
} = Astro.props;

const documentTitle = title ?? SITE_NAME;
const canonical =
  typeof canonicalURL === 'string' ? canonicalURL : canonicalURL.href;
const ogImageAbs = absUrl(ogImage);

const orgWebSiteLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'NewsMediaOrganization',
      '@id': `${SITE_URL}/#organization`,
      name: SITE_NAME,
      url: SITE_URL,
      slogan: SITE_TAGLINE,
      description: SITE_DESCRIPTION,
      logo: {
        '@type': 'ImageObject',
        url: PUBLISHER_LOGO,
        width: 600,
        height: 60,
      },
      sameAs: ORGANIZATION_SAME_AS,
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      name: SITE_NAME,
      url: SITE_URL,
      description: SITE_DESCRIPTION,
      publisher: { '@id': `${SITE_URL}/#organization` },
      inLanguage: 'en-US',
    },
  ],
};


---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_NAME} RSS`}
      href={new URL('/rss.xml', SITE_URL).href}
    />
    <link rel="icon" href="/favicon-48.png" type="image/png" sizes="48x48" />
    <link rel="icon" href="/favicon-192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <title>{documentTitle}</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(orgWebSiteLd)}
    />
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <script is:inline>
      // Breaking shows only on the publish calendar day (site TZ). Static host: no rebuild required.
      (function () {
        document.querySelectorAll('[data-breaking-day]').forEach(function (el) {
          var day = el.getAttribute('data-breaking-day');
          var tz = el.getAttribute('data-breaking-tz') || 'America/New_York';
          if (!day) return;
          var today = new Intl.DateTimeFormat('en-CA', {
            timeZone: tz,
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
          }).format(new Date());
          if (today > day) {
            el.remove();
          } else {
            el.removeAttribute('hidden');
          }
        });
      })();
    </script>
  </body>
</html>
