---
import '../styles/global.css';
import { SITE_DESCRIPTION, SITE_NAME, SITE_URL } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: URL | string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  canonicalURL = Astro.site
    ? new URL(Astro.url.pathname, Astro.site)
    : Astro.url,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const documentTitle = title ?? SITE_NAME;
const canonical =
  typeof canonicalURL === 'string' ? canonicalURL : canonicalURL.href;

const GA_ID = 'G-JZV2D683SW';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <title>{documentTitle}</title>
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'NewsMediaOrganization',
        name: SITE_NAME,
        url: SITE_URL,
        logo: {
          '@type': 'ImageObject',
          url: `${SITE_URL}/logo-600x60.svg`,
          width: 600,
          height: 60,
        },
      })}
    />
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
    ></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Breaking shows only on the publish calendar day (site TZ). Static host: no rebuild required.
      (function () {
        document.querySelectorAll('[data-breaking-day]').forEach(function (el) {
          var day = el.getAttribute('data-breaking-day');
          var tz = el.getAttribute('data-breaking-tz') || 'America/New_York';
          if (!day) return;
          var today = new Intl.DateTimeFormat('en-CA', {
            timeZone: tz,
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
          }).format(new Date());
          if (today > day) {
            el.remove();
          } else {
            el.removeAttribute('hidden');
          }
        });
      })();
    </script>
  </body>
</html>
