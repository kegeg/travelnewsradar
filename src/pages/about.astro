---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcon from '../components/SocialIcon.astro';
import {
  AUTHOR,
  SITE_NAME,
  SITE_URL,
  SOCIAL_LINKS,
} from '../consts';

const pageUrl = new URL('/about/', SITE_URL).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `About ${SITE_NAME}`,
  url: pageUrl,
  description: `${SITE_NAME} covers breaking travel news for travelers: what happened, what it means for your trip, and what to check next.`,
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_NAME,
    url: SITE_URL,
  },
  about: {
    '@type': 'NewsMediaOrganization',
    name: SITE_NAME,
    url: SITE_URL,
  },
  mainEntity: {
    '@type': 'Person',
    name: AUTHOR.name,
    url: new URL(AUTHOR.url, SITE_URL).href,
    jobTitle: AUTHOR.jobTitle,
  },
};
---

<BaseLayout
  title={`About ${SITE_NAME}`}
  description={`${SITE_NAME} covers breaking travel news for travelers in Canada and the US: flights, borders, advisories, and trip disruptions. What happened, what it means, and what to check next. Edited by ${AUTHOR.name}.`}
  jsonLd={jsonLd}
>
  <article class="article">
    <h1>About {SITE_NAME}</h1>
    <div class="article__body">
      <p>
        {SITE_NAME} is a travel news site for people who travel. We cover
        breaking stories that can affect all parts of a trip, from flights to
        border crossings, hotels, or whether you should change plans. But also
        airline and airport chaos, entry rules, advisories, strikes, and other
        travel news while it still matters.
      </p>
      <p>
        Our articles usually aim to answer these three questions: what happened,
        what it means for travelers, and what you should check next.
      </p>

      <h2>Who {SITE_NAME} is for</h2>
      <p>
        Mostly travelers from the United States or Canada planning any kind of
        trips, plus anyone else whose plans get affected by the same news:
        frequent flyers, long-term travelers, and people already on the road.
      </p>

      <h2>Editor</h2>
      <p>
        {SITE_NAME} is edited by{' '}
        <a href={AUTHOR.url}>{AUTHOR.name}</a>. He has been living on the road
        since 2018 and has visited {AUTHOR.countriesVisited} countries so far.
        More background is on his <a href={AUTHOR.url}>author page</a>.
      </p>

      <h2>Follow the news</h2>
      <p>
        New stories land on the <a href="/">homepage</a>. You can also follow{' '}
        {SITE_NAME} on social, get email alerts, or subscribe via RSS:
      </p>
      <ul class="about-follow">
        {
          SOCIAL_LINKS.map((item) => (
            <li>
              <a
                class="about-follow__link"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer me"
              >
                <span class="about-follow__icon" aria-hidden="true">
                  <SocialIcon network={item.id} />
                </span>
                <span>{item.label}</span>
              </a>
            </li>
          ))
        }
        <li>
          <a class="about-follow__link" href="/rss.xml">RSS feed</a>
        </li>
      </ul>
      <div class="about-signup">
        <p class="about-signup__label">Email alerts</p>
        <script
          async
          src="https://subscribe-forms.beehiiv.com/v3/loader.js"
          data-beehiiv-form="afa8077b-0891-4511-a3f9-527e5748637d"
          is:inline
        ></script>
      </div>
      <p>
        Questions? See <a href="/contact/">Contact</a>.
      </p>
    </div>
  </article>
</BaseLayout>
