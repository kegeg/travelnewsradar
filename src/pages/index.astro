---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StoryCard from '../components/StoryCard.astro';
import { SITE_NAME, SITE_TAGLINE } from '../consts';

const articles = (
  await getCollection('articles', ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [lead, ...rest] = articles;
---

<BaseLayout description={`${SITE_TAGLINE}. ${SITE_NAME} covers breaking travel news for travelers.`}>
  <h1 class="sr-only">{SITE_NAME}: {SITE_TAGLINE}</h1>

  <header class="masthead">
    <p class="masthead__label">Travel news</p>
    <p class="masthead__title">Latest</p>
  </header>

  {
    articles.length === 0 ? (
      <p>No articles yet.</p>
    ) : (
      <div class="home-feed">
        {lead && (
          <ol class="story-list story-list--lead">
            <StoryCard article={lead} variant="lead" />
          </ol>
        )}
        {rest.length > 0 && (
          <ol class="story-list story-list--grid">
            {rest.map((article) => (
              <StoryCard article={article} variant="card" />
            ))}
          </ol>
        )}
      </div>
    )
  }
</BaseLayout>
