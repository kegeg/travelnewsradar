---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StoryCard from '../components/StoryCard.astro';
import { SITE_DESCRIPTION, SITE_NAME } from '../consts';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [lead, ...rest] = articles;
---

<BaseLayout description={SITE_DESCRIPTION}>
  <h1 class="sr-only">{SITE_NAME} — latest travel news</h1>
  <p class="hero-label">
    <span class="hero-label__pip" aria-hidden="true"></span>
    Latest
  </p>

  {
    articles.length === 0 ? (
      <p>No articles yet.</p>
    ) : (
      <ol class="story-list">
        {lead && <StoryCard article={lead} lead />}
        {rest.map((article) => (
          <StoryCard article={article} />
        ))}
      </ol>
    )
  }
</BaseLayout>
